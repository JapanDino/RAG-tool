# Copy to backend/.env and adjust values before running docker-compose.

# Database (use Docker service name "db" when running via docker-compose)
DATABASE_URL=postgresql+psycopg://rag:rag_pass@db:5432/rag_db

# Redis (use Docker service name "redis" when running via docker-compose)
REDIS_URL=redis://redis:6379/0

# Embeddings: hash (no deps, fast) | local (sentence-transformers, semantic) | openai
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_LOCAL=intfloat/multilingual-e5-large

# Upload directory for documents
UPLOAD_DIR=/app/uploads

# OCR timeout per page in seconds (0 = no timeout)
OCR_PAGE_TIMEOUT_S=30

# LLM integration (optional)
ENABLE_LLM=0
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
